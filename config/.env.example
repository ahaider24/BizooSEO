# Bizoo SEO Engine - environment template
# Copy to .env on the droplet (/home/bizoo/engine/.env). Never commit .env.

# Anthropic
ANTHROPIC_API_KEY=

# SEO data
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
SERPAPI_KEY=
PERPLEXITY_API_KEY=

# Google
GSC_SERVICE_ACCOUNT_JSON_PATH=/home/bizoo/engine/gsc_service_account.json
YOUTUBE_DATA_API_KEY=

# Airtable
AIRTABLE_API_KEY=
AIRTABLE_BIZOO_SEO_BASE_ID=
AIRTABLE_BIZOO_CRM_BASE_ID=

# Slack
SLACK_WEBHOOK_BIZOO_SEO=
SLACK_WEBHOOK_BIZOO_CRM=

# PostHog (self-hosted)
POSTHOG_HOST=
POSTHOG_PROJECT_API_KEY=

# Loops.so
LOOPS_API_KEY=

# Site
BIZOO_DOMAIN=getbizoo.com
